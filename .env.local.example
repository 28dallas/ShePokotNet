# Copy to .env.local and fill values
NEXT_PUBLIC_SITE_NAME="She Pokot Network"
NEXT_PUBLIC_BASE_URL="https://your-deployed-site.vercel.app"

# Database
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://user:password@localhost:5432/she_pokot

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# M-Pesa (sandbox/production credentials)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# Analytics
NEXT_PUBLIC_GA_ID=
